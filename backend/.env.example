# --- Окружение backend ---
NODE_ENV=development
PORT=4000

# База данных.
# По умолчанию SQLite (файл рядом с проектом) — запуск без внешней БД.
DATABASE_URL="file:./dev.db"
# Для PostgreSQL (Docker Compose) — пример строки подключения:
# DATABASE_URL="postgresql://clinic:clinic@db:5432/clinic?schema=public"

# JWT
JWT_SECRET="change-me-in-production-please-32chars"
JWT_EXPIRES_IN=2h

# CORS — адрес фронтенда (Vite dev-сервер)
CORS_ORIGIN=http://localhost:5173

# Тестовые пользователи для сидинга и автотестов
SEED_PATIENT_EMAIL=patient@test.local
SEED_PATIENT_PASSWORD=Patient123!
SEED_REGISTRAR_EMAIL=registrar@test.local
SEED_REGISTRAR_PASSWORD=Registrar123!
